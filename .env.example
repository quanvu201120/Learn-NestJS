# =========================
# APP
# =========================
PORT=8080
NODE_ENV=
CORS_ORIGINS=http://localhost:5173
# =========================
# SYSTEM ADMIN AUTO BAN
# =========================
SYSTEM_ADMIN_ID=
# =========================
# DATABASE (MongoDB)
# =========================
MONGODB_URI=mongodb://username:password@localhost:27017/database_name?authSource=admin
# =========================
# GOOGLE
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# =========================
# REDIS
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# =========================
# JWT
# NOTE: giữ nguyên key JWT_EXPRIRES_IN để khớp code hiện tại
# =========================
JWT_SECRET=your_jwt_secret_here
JWT_EXPRIRES_IN=30m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN_DB=7d
COOKIE_EXPIRES_IN=7d
REFRESH_TOKEN_PEPPER=your_refresh_token_pepper
APPEAL_TOKEN_SECRET=your_appeal_token_secret_here
APPEAL_TOKEN_EXPIRES_IN=10m
# =========================
# OTP / VERIFY
# =========================
CODE_VERIFY_PEPPER=your_code_verify_pepper
MAIL_CODE_ACTIVE_EXPIRE=1h
MAIL_CODE_FORGOT_EXPIRE=5m
MAIL_CODE_UPDATE_EMAIL_EXPIRE=5m
# =========================
# MAIL (Resend HTTP API)
# =========================
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM='"No Reply" <onboarding@resend.dev>'
MAIL_REGISTER_TEMPLATE=register
MAIL_FORGOT_TEMPLATE=forgot-password
MAIL_UPDATE_EMAIL_TEMPLATE=verify-new-email
# =========================
# CLOUDINARY
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Bật TTL thật cho signed URL media riêng tư (chỉ có ở gói Cloudinary trả phí).
# Free tier để 'false'.
CLOUDINARY_AUTH_TOKEN_ENABLED=false
CLOUDINARY_AUTH_TOKEN_KEY=

# =========================
# CLOUDFLARE R2
# =========================
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
CLOUDFLARE_API_TOKEN=
# =========================
# STORAGE LIMITS (GB)
# =========================
CLOUDINARY_BANDWIDTH_LIMIT_GB=
CLOUDINARY_STORAGE_LIMIT_GB=
R2_STORAGE_LIMIT_GB=
MONGO_MAX_STORAGE_MB=
REDIS_MAX_MEMORY_MB=
# =========================
#WEB PUSH - npx web-push generate-vapid-keys
# =========================
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# =========================
# WEBRTC / METERED TURN-STUN
# =========================
METERED_API_KEY=your_metered_api_key_here
METERED_ICE_SERVERS_URL=https://yourappname.metered.live/api/v1/turn/credentials
