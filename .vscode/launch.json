{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug NestJS",
            "args": ["run", "start:debug"],
            "runtimeExecutable": "npm",
            "console": "integratedTerminal",
            "restart": true,
            "sourceMaps": true,
            "protocol": "inspector",
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/node_modules/**"
            ]
        }
    ]
}
